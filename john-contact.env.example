# Optional local-only send settings for tools/send_to_john.sh.
# Copy to john-contact.env, or run tools/setup-drive-upload.sh on the Pi.

# Preferred: Google Drive upload with rclone.
# Shared folder:
# https://drive.google.com/drive/folders/1QYtv2RmXZq8g6iEgjdxn2W2cG39L_TYW?usp=sharing
JOHN_RCLONE_TARGET="escape-room-drive:"
JOHN_RCLONE_ROOT_FOLDER_ID="1QYtv2RmXZq8g6iEgjdxn2W2cG39L_TYW"

# Upload endpoint that accepts multipart form field "file".
JOHN_UPLOAD_URL=""

# SCP target, for example: user@example.com:/home/user/uploads/
JOHN_SCP_TARGET=""

# Email address. Requires mutt or mail/mailx configured on the Raspberry Pi.
JOHN_EMAIL=""
JOHN_EMAIL_SUBJECT="Escape room fire-panel button order log"
