# Optional local-only send settings for tools/send_to_john.sh.
# Copy to john-contact.env and set one of these if you want automatic sending.

# Upload endpoint that accepts multipart form field "file".
JOHN_UPLOAD_URL=""

# SCP target, for example: user@example.com:/home/user/uploads/
JOHN_SCP_TARGET=""

# Email address. Requires mutt or mail/mailx configured on the Raspberry Pi.
JOHN_EMAIL=""
JOHN_EMAIL_SUBJECT="Escape room fire-panel button order log"
